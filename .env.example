# ========================================
# VARIABLES DE ENTORNO (TEMPLATE)
# ========================================

# --- FRONTEND (Next.js - Variables Públicas) ---
# Usar URL local para desarrollo, y la de Render para producción
NEXT_PUBLIC_API_URL=http://localhost:8000/api/v1
# NEXT_PUBLIC_API_URL=https://multimodal-saas-api.onrender.com/api/v1

# --- BACKEND (FastAPI - Privado) ---
PROJECT_NAME="SaaS Multimodal Inteligente"
API_V1_STR="/api/v1"

# --- MULTIMODAL / IA (Si se conectaran APIs externas como OpenAI/Gemini en vez de local) ---
# OPENAI_API_KEY=sk-xxxxxx
# GEMINI_API_KEY=AIxxxxxx

# --- DATABASE / VECTORSTORE ---
# VECTOR_FAISS_PATH="./faiss_index"

# --- SEGURIDAD ---
# SECRET_KEY=your_secure_secret_hash
